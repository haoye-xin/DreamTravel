<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.dreamtravel.ui.onboarding.OnboardingFragment"
        android:label="引导"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_placeList"
            app:destination="@id/placeListFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/placeListFragment"
        android:name="com.dreamtravel.ui.places.PlaceListFragment"
        android:label="梦想之地"
        tools:layout="@layout/fragment_place_list">
        <action
            android:id="@+id/action_placeList_to_addPlace"
            app:destination="@id/addPlaceFragment" />
        <action
            android:id="@+id/action_placeList_to_todoList"
            app:destination="@id/todoListFragment" />
        <action
            android:id="@+id/action_placeList_to_map"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_placeList_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addPlaceFragment"
        android:name="com.dreamtravel.ui.places.AddPlaceFragment"
        android:label="添加梦想之地"
        tools:layout="@layout/fragment_add_place" />

    <fragment
        android:id="@+id/todoListFragment"
        android:name="com.dreamtravel.ui.todos.TodoListFragment"
        android:label="待办事项"
        tools:layout="@layout/fragment_todo_list">
        <argument
            android:name="placeId"
            app:argType="string" />
        <argument
            android:name="placeName"
            app:argType="string" />
        <action
            android:id="@+id/action_todoList_to_addTodo"
            app:destination="@id/addTodoFragment" />
    </fragment>

    <dialog
        android:id="@+id/addTodoFragment"
        android:name="com.dreamtravel.ui.todos.AddTodoFragment"
        android:label="添加待办"
        tools:layout="@layout/fragment_add_todo">
        <argument
            android:name="placeId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="todoId"
            app:argType="string"
            android:defaultValue="" />
    </dialog>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.dreamtravel.ui.map.MapFragment"
        android:label="地图"
        tools:layout="@layout/fragment_map">
        <action
            android:id="@+id/action_map_to_todoList"
            app:destination="@id/todoListFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.dreamtravel.ui.settings.SettingsFragment"
        android:label="设置"
        tools:layout="@layout/fragment_settings" />

</navigation>
